# --- TikTok Studio config -----------------------------------------------------
# Copy to ".env" and fill in. The app runs fine without Brevo (emails go to a
# logged "dry run") until you paste the SMTP key.

PORT=4317
TZ=Europe/Warsaw

# Brevo (Sendinblue) SMTP — get these from https://app.brevo.com → SMTP & API
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=

# From/To for all studio emails
MAIL_FROM=TikTok Studio <softsynerg@gmail.com>
MAIL_TO=softsynerg@gmail.com

# Optional: override DB location (defaults to ./data/studio.db)
# DB_PATH=/var/lib/tiktok-studio/studio.db
