# --- TikTok Studio config -----------------------------------------------------
# Copy to ".env" and fill in. The app runs fine without Brevo (emails go to a
# logged "dry run") until you paste the SMTP key.

PORT=4317
TZ=Europe/Warsaw

# Brevo (Sendinblue) SMTP — get these from https://app.brevo.com → SMTP & API
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=
BREVO_SMTP_KEY=

# From/To for all studio emails
MAIL_FROM=TikTok Studio <softsynerg@gmail.com>
MAIL_TO=softsynerg@gmail.com

# Optional: override DB location (defaults to ./data/studio.db)
# DB_PATH=/var/lib/tiktok-studio/studio.db

# --- Generator (headless Claude Code agent) -----------------------------------
# "✨ Generuj filmik" in the render queue spawns the local `claude` CLI, which
# builds + renders a HyperFrames video and registers it back into the Studio.
# Works ONLY on a machine where `claude` is installed (your Mac) — not the VPS.
#
# The headless agent needs its OWN Anthropic API key (it can't borrow a logged-in
# human session). Paste one here, like you do with Brevo, then restart:
AGENT_ANTHROPIC_API_KEY=
# AGENT_ENABLED=1            # set 0 to hide the generator entirely
# AGENT_MODEL=sonnet         # model the agent runs on
# AGENT_MAX_CONCURRENT=1     # how many videos may render at once
# AGENT_REPO_ROOT=           # monorepo root (defaults to one level above this app)
# AGENT_KEEP_ENV=1           # keep inherited ANTHROPIC_* env instead of cleaning it
